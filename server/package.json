{
    "name":  "@lucky-shop/server",
    "version":  "5.0.0",
    "private":  true,
    "description":  "LuckyShop Backend - Express + Prisma + TypeScript",
    "main":  "dist/index.js",
    "scripts":  {
                    "dev":  "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
                    "build":  "tsc -p tsconfig.json",
                    "start":  "node dist/index.js",
                    "typecheck":  "tsc --noEmit",
                    "lint":  "eslint . --ext .ts --max-warnings 0",
                    "lint:fix":  "eslint . --ext .ts --fix",
                    "test":  "jest --runInBand --passWithNoTests",
                    "test:watch":  "jest --watch --runInBand",
                    "test:coverage":  "jest --runInBand --coverage"
                },
    "dependencies":  {
                         "@prisma/client":  "^5.15.0",
                         "bcryptjs":  "^2.4.3",
                         "compression":  "^1.7.4",
                         "cookie-parser":  "^1.4.6",
                         "cors":  "^2.8.5",
                         "dayjs":  "^1.11.11",
                         "dotenv":  "^16.4.5",
                         "express":  "^4.19.2",
                         "express-rate-limit":  "^7.4.0",
                         "helmet":  "^7.2.0",
                         "jsonwebtoken":  "^9.0.2",
                         "lru-cache":  "^10.2.0",
                         "morgan":  "^1.10.0",
                         "multer":  "^1.4.5-lts.1",
                         "nanoid":  "^3.3.7",
                         "node-cron":  "^3.0.3",
                         "rate-limit-redis":  "^4.2.0",
                         "sharp":  "^0.33.4",
                         "winston":  "^3.13.0",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@types/bcryptjs":  "^2.4.6",
                            "@types/compression":  "^1.7.5",
                            "@types/cookie-parser":  "^1.4.7",
                            "@types/cors":  "^2.8.17",
                            "@types/express":  "^4.17.21",
                            "@types/jest":  "^29.5.12",
                            "@types/jsonwebtoken":  "^9.0.6",
                            "@types/morgan":  "^1.9.9",
                            "@types/multer":  "^1.4.11",
                            "@types/node":  "^20.14.0",
                            "@types/node-cron":  "^3.0.11",
                            "@types/supertest":  "^6.0.2",
                            "jest":  "^29.7.0",
                            "nodemon":  "^3.1.4",
                            "prisma":  "^5.15.0",
                            "supertest":  "^7.0.0",
                            "ts-jest":  "^29.2.0",
                            "ts-node":  "^10.9.2",
                            "tsx":  "^4.16.0",
                            "typescript":  "^5.5.0"
                        }
}