# LuckyShop 5.1 — Environment Configuration
#
# ═══════════════ SECURITY NOTES ═══════════════
# - .env 文件已在 .gitignore 中，切勿提交到仓库
# - 生产环境 JWT_SECRET 至少 32 位随机字符
# - 生产环境 DATABASE_URL 应使用强密码
# - 生产环境务必设置 NODE_ENV=production
# ═══════════════════════════════════════════════

# Node Environment
NODE_ENV=development

# Server
PORT=4000
HOST=0.0.0.0

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL production example:
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:STRONG_PASSWORD@host:5432/lucky_shop?schema=public"

# Connection Pool (PostgreSQL only)
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=30000

# JWT — 生产环境务必更换为 32+ 位随机字符串
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# CORS — 生产环境设置为实际域名，逗号分隔
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880

# Logging
# 生产环境推荐: LOG_LEVEL=warn 或 error
LOG_LEVEL=info
LOG_DIR=./logs

# Rate Limit — 生产环境可根据实际负载调整
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Redis (optional — 生产环境推荐启用)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
